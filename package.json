{
  "name": "@senjinthedragon/sillytavern-discord-connector",
  "version": "1.2.1",
  "description": "Full-featured Discord bridge for SillyTavern with image support and slash commands.",
  "files": [
    "index.js",
    "manifest.json",
    "settings.html",
    "style.css",
    "server/*.js",
    "server/package.json",
    "server/config.example.js",
    "server/start-bridge.bat",
    "!server/config.js"
  ],
  "main": "server/server.js",
  "scripts": {
    "version": "version-everything manifest.json server/package.json && git add manifest.json server/package.json",
    "bump": "npm version patch",
    "bump-minor": "npm version minor",
    "bump-major": "npm version major",
    "test-package": "npm pack --dry-run",
    "install-server": "cd server && npm install",
    "start": "cd server && node server.js"
  },
  "author": "Senjin the Dragon <https://github.com/senjinthedragon>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senjinthedragon/SillyTavern-Discord-Connector.git"
  },
  "bugs": {
    "url": "https://github.com/senjinthedragon/SillyTavern-Discord-Connector/issues"
  },
  "homepage": "https://github.com/senjinthedragon/SillyTavern-Discord-Connector#readme",
  "devDependencies": {
    "version-everything": "^0.11.4"
  }
}
